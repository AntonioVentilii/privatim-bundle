# Copy to .env.local and fill in the values from `icp canister status <name>`
# after a local `icp deploy`. Only read in dev (when the asset canister's
# ic_env cookie isn't present).

# VITE_CANISTER_ID_APP_BACKEND=
# VITE_CANISTER_ID_AI_ASSISTANT=

# Optional: override the local replica URL (defaults to icp 0.2.6's pocket-ic
# gateway port). Confirm with `icp network status`.
# IC_REPLICA_URL=http://127.0.0.1:8000
