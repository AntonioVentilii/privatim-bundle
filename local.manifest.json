{
	"manifest_version": 1,
	"name": "Privatim",
	"short_name": "Sovereign AI for private banking",
	"application_version": "0.3.4",
	"description": "An auditable, jurisdiction-locked private-banking workspace with an on-engine AI assistant. Six-canister architecture: identity, audit, data, documents (client-side encrypted), ai_assistant, web_frontend.",
	"main_canister": "web_frontend",

	"canisters": {
		"identity": {
			"dependencies": [],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"audit": {
			"dependencies": ["identity"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"data": {
			"dependencies": ["identity", "audit"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"documents": {
			"dependencies": ["audit"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"ai_assistant": {
			"dependencies": ["identity", "audit", "data"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"web_frontend": {
			"dependencies": ["identity", "audit", "data", "documents", "ai_assistant"],
			"env_variables": {
				"PUBLIC_II_CANISTER_ID": "uqzsh-gqaaa-aaaaq-qaada-cai"
			},
			"asset_dir": "./web_frontend/dist"
		}
	},

	"icons": [
		{ "src": "./icons/app.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{ "src": "./icons/identity.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{ "src": "./icons/audit.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{ "src": "./icons/data.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{
			"src": "./icons/documents.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "./icons/ai_assistant.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "./icons/web_frontend.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		}
	],

	"screenshots": [
		{ "src": "./screenshots/thumbnail.jpg", "sizes": "1280x853", "type": "image/jpeg" }
	]
}
