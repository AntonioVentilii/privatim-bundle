{
	"manifest_version": 1,
	"name": "Privatim",
	"short_name": "Sovereign AI for private banking",
	"application_version": "0.1.0",
	"description": "An auditable, jurisdiction-locked private-banking workspace with an on-engine AI assistant. Designed for Swiss private banks where client data must not leave the bank's compute.",
	"main_canister": "web_frontend",

	"canisters": {
		"app_backend": {
			"dependencies": [],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"ai_assistant": {
			"dependencies": ["app_backend"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"web_frontend": {
			"dependencies": ["app_backend", "ai_assistant"],
			"env_variables": {
				"PUBLIC_II_CANISTER_ID": "uqzsh-gqaaa-aaaaq-qaada-cai"
			},
			"asset_dir": "./web_frontend/dist"
		}
	},

	"icons": [
		{ "src": "./icons/app.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{
			"src": "./icons/app_backend.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "./icons/ai_assistant.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "./icons/web_frontend.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		}
	],

	"screenshots": []
}
