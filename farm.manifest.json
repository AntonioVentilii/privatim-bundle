{
	"manifest_version": 1,
	"name": "Privatim",
	"short_name": "Sovereign private banking",
	"application_version": "1.0.4",
	"description": "Auditable private-banking workspace.",
	"main_canister": "web_frontend",

	"canisters": {
		"identity": {
			"dependencies": [],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"audit": {
			"dependencies": ["identity"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"data": {
			"dependencies": ["identity", "audit"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"documents": {
			"dependencies": ["audit"],
			"init_arg": { "arg": "()", "format": "candid" }
		},
		"web_frontend": {
			"dependencies": ["identity", "audit", "data", "documents"],
			"env_variables": {
				"PUBLIC_II_CANISTER_ID": "s24we-diaaa-aaaaa-aaaka-cai"
			},
			"asset_dir": "./web_frontend/dist"
		}
	},

	"icons": [
		{ "src": "./icons/app.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{ "src": "./icons/identity.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{ "src": "./icons/audit.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{ "src": "./icons/data.svg", "sizes": "any", "type": "image/svg+xml", "purpose": "any" },
		{
			"src": "./icons/documents.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		},
		{
			"src": "./icons/web_frontend.svg",
			"sizes": "any",
			"type": "image/svg+xml",
			"purpose": "any"
		}
	],

	"screenshots": [
		{ "src": "./screenshots/thumbnail.jpg", "sizes": "1280x853", "type": "image/jpeg" },
		{ "src": "./screenshots/privatim-1.webp", "sizes": "1536x1024", "type": "image/webp" },
		{ "src": "./screenshots/privatim-1-1.webp", "sizes": "1536x1024", "type": "image/webp" },
		{ "src": "./screenshots/privatim-1-2.webp", "sizes": "1536x1024", "type": "image/webp" }
	]
}
